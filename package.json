{
  "name": "dnd-character-sheet",
  "version": "1.0.0",
  "description": "Single-page fillable D&D character sheet with PDF export and AI-powered import",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && set ELECTRON_DEV=true&& electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.vanfreyr.dndcharactersheet",
    "productName": "Vanfreyr's Character Sheet",
    "directories": {
      "output": "release"
    },
    "afterExtract": "electron/after-extract.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/vanfreyr.ico",
      "package.json"
    ],
    "win": {
      "icon": "build/vanfreyr.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.5.31",
    "jszip": "^3.10.1",
    "mammoth": "^1.6.0",
    "pdfjs-dist": "^4.0.379",
    "solid-js": "^1.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.3.1",
    "electron-builder": "^26.8.1",
    "resedit": "^1.7.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.11.12",
    "wait-on": "^9.0.10"
  }
}
